@inject IJSRuntime JSRuntime

<div class="invert-toggle" @onclick="ToggleInvert">
    <button class="btn btn-sm btn-outline-secondary rounded-circle shadow" title="Invert Snippets">
        @if (_isInverted)
        {
            <span>🔄</span>
        }
        else
        {
            <span>🖼️</span>
        }
    </button>
</div>

<style>
    .invert-toggle {
        position: fixed;
        bottom: 75px;
        right: 20px;
        z-index: 1000;
    }
    .invert-toggle button {
        width: 45px;
        height: 45px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1.2rem;
        background-color: var(--card-bg);
        border: 1px solid var(--border-color);
        color: var(--text-color);
    }
</style>

@code {
    private bool _isInverted = false;

    private async Task ToggleInvert()
    {
        _isInverted = !_isInverted;
        await JSRuntime.InvokeVoidAsync("toggleInvertSnippets", _isInverted);
    }
}
